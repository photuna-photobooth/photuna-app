{
  "name": "photuna-app",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "main": "electron/main.js",
  "description": "Studio Photuna – Ahead of the moment",
  "author": "Studio Photuna <admin@studiophotuna.com>",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.104.1",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.24",
    "fs-extra": "^11.3.3",
    "idb-keyval": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "keytar": "^7.9.0",
    "konva": "^10.0.2",
    "mime": "^4.1.0",
    "mongodb": "^7.0.0",
    "mysql2": "^3.16.0",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.0.10",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.2.1",
    "stripe": "^22.1.0",
    "use-image": "^1.1.4",
    "webfontloader": "^1.6.28"
  },
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"npm run electron-start\"",
    "react-start": "cross-env BROWSER=none react-scripts start",
    "electron": "cross-env ELECTRON_START_URL=http://localhost:3000 electron . --no-watcher",
    "electron-start": "wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron . --no-watcher",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "eject": "react-scripts eject",
    "start:all": "concurrently -n WEB,ELECTRON -c \"bgBlue.bold,bgMagenta.bold\" \"npm:react-start\" \"npm:electron-start\""
  },
  "build": {
    "extends": null,
    "appId": "com.photuna.app",
    "productName": "Photuna Booth App",
    "electronDist": "node_modules/electron/dist",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "!electron/bin/PhotoPrintHelper/**/*",
      "!electron/bin/photo-print-helper.exe"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "electron/bin/photo-print-helper.exe",
        "to": "bin/photo-print-helper.exe"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.18",
    "wait-on": "^9.0.1",
    "web-vitals": "^2.1.4"
  },
  "keywords": [],
  "license": "ISC"
}
